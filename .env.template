# claude-observer configuration
# Copy to .env (next to the js files) — all three processes read it.
# Precedence: CLI flag > real environment variable > .env > default.

# Shared secret between hub, reporters, and dashboards (required)
CLAUDE_OBSERVER_TOKEN=

# Hub URL for reporter and dashboard (e.g. https://hub.example.com/observer)
CLAUDE_OBSERVER_HUB_URL=http://127.0.0.1:7345

# --- reporter (optional) ---
# Display name for this machine (default: hostname)
#CLAUDE_OBSERVER_MACHINE=mac-mini
# Shown in the dashboard's ssh-attach hint (default: machine name)
#CLAUDE_OBSERVER_SSH_HINT=marco@mini.local
# Push interval in seconds (default: 3)
#CLAUDE_OBSERVER_PUSH_INTERVAL_S=3

# --- hub (optional) ---
# Port to listen on (default: 7345)
#CLAUDE_OBSERVER_HUB_PORT=7345
# Bind address (default: 127.0.0.1 — keep it that way behind a reverse proxy)
#CLAUDE_OBSERVER_HUB_BIND=127.0.0.1
# Seconds without a report before a machine counts as stale (default: 15)
#CLAUDE_OBSERVER_STALE_S=15
