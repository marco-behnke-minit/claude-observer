# claude-observer dashboard — terminal UI polling the hub.
# Needs an interactive TTY (-it) for rendering and keyboard input:
#   docker run -it --env-file .env ghcr.io/<owner>/claude-observer-dashboard
#   docker run -it -v ./.env:/app/.env ghcr.io/<owner>/claude-observer-dashboard
# Desktop notifications (osascript) are macOS-only and silently skipped in
# the container; the bell and on-screen banner still work.
FROM node:22-alpine

WORKDIR /app
COPY dashboard.js collector.js .

USER node
CMD ["node", "dashboard.js"]
